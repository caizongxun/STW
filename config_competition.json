{
  "competition_mode": true,
  "update_interval_minutes": 15,
  
  "api_keys": {
    "OPENROUTER_API_KEY": "sk-or-v1-YOUR_KEY_HERE",
    "GROQ_API_KEY": "gsk_YOUR_KEY_HERE",
    "GOOGLE_API_KEY": "AIza_YOUR_KEY_HERE",
    "DEEPSEEK_API_KEY": "sk-YOUR_KEY_HERE"
  },
  
  "model_strategy": {
    "mode": "triple_consensus",
    "description": "三模型共識決策，適合AI競賽",
    
    "primary_model": {
      "provider": "OpenRouter",
      "model": "meta-llama/llama-3.1-405b-instruct:free",
      "priority": 10,
      "reason": "最強推理能力，405B參數",
      "daily_limit": 200,
      "monthly_quota": 6000
    },
    
    "secondary_model": {
      "provider": "OpenRouter",
      "model": "google/gemini-2.0-flash-thinking-exp:free",
      "priority": 9,
      "reason": "思維鏈推理，1M context",
      "daily_limit": 200,
      "monthly_quota": 6000
    },
    
    "tertiary_model": {
      "provider": "Groq",
      "model": "llama-3.3-70b-versatile",
      "priority": 8,
      "reason": "速度快，高額度備份",
      "daily_limit": 14400,
      "monthly_quota": 432000
    },
    
    "emergency_backup": {
      "provider": "Google",
      "model": "gemini-2.0-flash",
      "priority": 7,
      "reason": "緊急備用",
      "daily_limit": 1500,
      "monthly_quota": 45000
    }
  },
  
  "decision_logic": {
    "consensus_threshold": 2,
    "description": "至少2個模型同意才執行交易",
    
    "rules": [
      "如果 Llama 405B + Gemini 2.0 同意 → 執行 (信心度 90%)",
      "如果 Llama 405B + Llama 70B 同意 → 執行 (信心度 85%)",
      "如果 Gemini 2.0 + Llama 70B 同意 → 執行 (信心度 80%)",
      "如果三個模型不同意 → HOLD (等待下次)"
    ],
    
    "weights": {
      "meta-llama/llama-3.1-405b-instruct:free": 0.45,
      "google/gemini-2.0-flash-thinking-exp:free": 0.35,
      "llama-3.3-70b-versatile": 0.20
    }
  },
  
  "risk_management": {
    "max_position_size_usdt": 1000,
    "max_leverage": 5,
    "stop_loss_percentage": 2,
    "take_profit_percentage": 5,
    "daily_loss_limit": 100,
    "min_confidence_to_trade": 75
  },
  
  "performance_tracking": {
    "log_all_decisions": true,
    "save_model_outputs": true,
    "track_agreement_rate": true,
    "record_execution_time": true
  },
  
  "quota_management": {
    "daily_request_estimate": 96,
    "monthly_request_estimate": 2880,
    
    "allocation_strategy": {
      "openrouter_llama_405b": "60次/天 (主力分析)",
      "openrouter_gemini_2": "60次/天 (思維鏈驗證)",
      "groq_llama_70b": "96次/天 (全天候備份)",
      "google_gemini": "備用 (API故障時)"
    },
    
    "notes": [
      "OpenRouter 兩個模型共120次/天，足夠使用",
      "Groq 14400次/天，可作為主力備份",
      "Google Gemini 1500次/天，緊急備用",
      "總額度 > 16,000次/天，遠超需求"
    ]
  },
  
  "competition_optimizations": {
    "focus_on_accuracy": true,
    "enable_thinking_chain": true,
    "detailed_reasoning": true,
    "multi_timeframe_analysis": ["15m", "1h", "4h"],
    "technical_indicators": [
      "RSI",
      "MACD",
      "Bollinger Bands",
      "ATR",
      "EMA",
      "Volume",
      "Support/Resistance"
    ]
  }
}
