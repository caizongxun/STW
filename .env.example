# 多 API 配置范例
# 复制此文件为 .env 并填入你的 API Key

# ===========================================
# 1. Groq - 速度最快 (每天 14,400 请求)
# ===========================================
# 注册: https://console.groq.com
# 模型: Llama 3.1 70B, Mixtral 8x7B
# 特点: 极速推理 (200+ tokens/s)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 2. OpenRouter - 多模型整合 (每天 50-1000 请求)
# ===========================================
# 注册: https://openrouter.ai
# 模型: DeepSeek R1, Llama, Qwen, Mistral
# 特点: 20+ 免费模型
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 3. Google AI Studio - Gemini 2.5 Pro (每天 1,500 请求)
# ===========================================
# 注册: https://aistudio.google.com
# 模型: Gemini 2.5 Pro
# 特点: 推理最强，多模态支持
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 4. GitHub Models (需要 GitHub 账号)
# ===========================================
# 注册: https://github.com/marketplace/models
# 模型: GPT-4o mini, Llama, Phi-3
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 5. Cloudflare Workers AI (每天 10,000 请求)
# ===========================================
# 注册: https://dash.cloudflare.com
CLOUDFLARE_API_KEY=xxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 其他配置
# ===========================================

# Binance API (可选)
BINANCE_API_KEY=xxxxxxxxxxxxxxxxxxxxx
BINANCE_API_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Bybit API (可选)
BYBIT_API_KEY=xxxxxxxxxxxxxxxxxxxxx
BYBIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxx

# 多模型集成配置
MIN_MODELS_FOR_CONSENSUS=2  # 最少需要几个模型达成共识
MAX_MODELS_PER_REQUEST=3    # 每次最多调用几个模型
ENABLE_ENSEMBLE=true         # 是否启用集成决策
